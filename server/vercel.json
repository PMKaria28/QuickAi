{
  "version": 2,
  
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  
  "comment": "OLD CONFIG - Keeping for reference",
  "_old_builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**"
        ]
      }
    }
  ],
  "_old_routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}